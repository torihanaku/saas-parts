{
  "name": "saas-parts",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "SaaS開発でよく必要になる配管を、自己完結・依存注入式・テスト付きで提供するTypeScript部品集（112パッケージ）",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/torihanaku/saas-parts.git"
  },
  "homepage": "https://github.com/torihanaku/saas-parts#readme",
  "bugs": {
    "url": "https://github.com/torihanaku/saas-parts/issues"
  },
  "keywords": [
    "saas",
    "typescript",
    "monorepo",
    "multi-tenant",
    "rls",
    "auth",
    "stripe",
    "audit-log",
    "gdpr",
    "building-blocks"
  ],
  "author": "torihanaku",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "test:property": "vitest run **/*.property.test.ts",
    "test:rls": "bash scripts/run-rls-test.sh",
    "mutation": "stryker run"
  },
  "devDependencies": {
    "@node-saml/node-saml": "^5.1.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3": "^7",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "d3": "^7",
    "fast-check": "^4.9.0",
    "ioredis": "^5.11.1",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "resend": "^6.17.2",
    "stripe": "^22.3.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  }
}
